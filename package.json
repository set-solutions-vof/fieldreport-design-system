{
  "name": "@set-solutions-vof/design-system",
  "version": "0.1.5",
  "description": "Design tokens, brand assets, and React components for the FieldReport product suite",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/set-solutions-vof/fieldreport-design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "@set-solutions-vof:registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "tokens.css",
    "brand/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "dts-bundle-generator": "^9.5.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.2"
  }
}
